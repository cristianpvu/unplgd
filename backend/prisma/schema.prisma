// Schema incrementala. Modele viitoare planificate:
// Avatar + AvatarItem, GameSession + rounds/answers, PetSpecies + NfcCard + UserPet,
// Achievements. Le adaugam pe masura ce construim feature-urile.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  birthDate    DateTime
  xp           Int      @default(0)
  level        Int      @default(1)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Cheia fundalului de profil selectat (din ProfileBackground.key, deblocat
  // prin story-adventure). Vizibil de ceilalti pe profil. NULL = default.
  selectedBackgroundKey String?

  friendshipsSent         Friendship[]           @relation("FriendshipRequester")
  friendshipsReceived     Friendship[]           @relation("FriendshipReceiver")
  interactionsAsA         DailyInteraction[]     @relation("InteractionUser")
  interactionsAsB         DailyInteraction[]     @relation("InteractionFriend")
  xpTransactions          XpTransaction[]
  avatar                  Avatar?
  bracelet                NfcBracelet?
  pet                     Pet?
  petCards                NfcPetCard[]
  stories                 Story[]
  storyClaims             StoryClaim[]
  coCreationsAsA          CoCreation[]           @relation("CoCreationUserA")
  coCreationsAsB          CoCreation[]           @relation("CoCreationUserB")
  huntsHosted             HuntSession[]          @relation("HuntHost")
  huntTeamships           HuntTeamMember[]
  huntChallengeRuns       HuntChallengeRun[]
  huntLobbyMemberships    HuntLobbyMember[]
  phoneDownSessionsHosted PhoneDownSession[]     @relation("PhoneDownHost")
  phoneDownParticipations PhoneDownParticipant[]
  chests                  Chest[]
  ownedItems              UserItem[]
  adventureRuns           AdventureRun[]
  backgroundUnlocks       UserBackground[]
  journeyChapterProgress  JourneyChapterProgress[]

  @@index([email])
}

// Legare cont <-> bratara NFC. UID-ul tag-ului (hardcodat de fabrica, citit la
// scanare) e unic per user. MVP: o bratara per cont; re-provisioning-ul
// suprascrie inregistrarea existenta.
model NfcBracelet {
  id            String   @id @default(cuid())
  uid           String   @unique
  userId        String   @unique
  provisionedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Catalogul de iteme. ItemType = slotul (skin, hair, top...), Item = optiunea
// concreta (skin-02 "Nisip"). Datele sunt seed-uite din prisma/seed.ts. Slug-ul
// e identificatorul stabil folosit in API-ul cu mobile (mobile trimite "skin-02",
// backend rezolva la id intern).
// `group` separa tab-urile mari din editor: "face" (ten, par, ochi...) vs
// "body" (top, pantaloni, ghete...). Stocat ca string nu enum ca sa adaugam
// usor grupuri noi (ex: "accessories") fara migrare de schema.
model ItemType {
  id        String @id @default(cuid())
  slug      String @unique
  name      String
  group     String
  sortOrder Int    @default(0)

  items Item[]
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

// Punct de atasare pe corp pentru itemele de accesorii. Body composer-ul
// alege pozitia SVG in functie de aceasta: HAND la pumn, NECK la gat, FEET
// la picior, BACK in spate, HEAD deasupra capului. NULL pentru iteme care
// nu apartin slot-ului holding (skin, hair, top, etc.).
enum AttachmentPoint {
  HAND
  NECK
  FEET
  BACK
  HEAD
}

model Item {
  id              String           @id @default(cuid())
  typeId          String
  slug            String           @unique
  name            String
  // Codul de redare folosit de DiceBear / body composer. NULL = "fara"
  // (ochelari, cercei, vesta, holding) — opt-out explicit, item real in catalog.
  feature         String?
  level           Int              @default(1)
  sortOrder       Int              @default(0)
  // Raritatea picarii din cufere; influenteaza loot table weighting + culoarea
  // de prezentare in inventar.
  rarity          Rarity           @default(COMMON)
  // Iteme legendare obtenibile DOAR din PhoneDown (prestigiu social). False
  // pentru iteme catalog standard care vin oricum din avatar default sau
  // unlock la level.
  exclusive       Boolean          @default(false)
  // Doar pentru iteme din slot accesoriu (legacy slot "holding"). NULL pentru
  // restul sloturilor.
  attachmentPoint AttachmentPoint?

  type ItemType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  // Echipari per slot — cate o relatie nominala pentru fiecare FK pe Avatar,
  // ca Prisma sa stie sa reverse-lookup-uiasca corect.
  equippedAsSkin      Avatar[] @relation("AvatarSkin")
  equippedAsHairColor Avatar[] @relation("AvatarHairColor")
  equippedAsHair      Avatar[] @relation("AvatarHair")
  equippedAsEyes      Avatar[] @relation("AvatarEyes")
  equippedAsMouth     Avatar[] @relation("AvatarMouth")
  equippedAsEyebrows  Avatar[] @relation("AvatarEyebrows")
  equippedAsGlasses   Avatar[] @relation("AvatarGlasses")
  equippedAsEarrings  Avatar[] @relation("AvatarEarrings")
  equippedAsFeatures  Avatar[] @relation("AvatarFeatures")
  equippedAsBodyShape Avatar[] @relation("AvatarBodyShape")
  equippedAsTop       Avatar[] @relation("AvatarTop")
  equippedAsOuterwear Avatar[] @relation("AvatarOuterwear")
  equippedAsBottom    Avatar[] @relation("AvatarBottom")
  equippedAsFootwear  Avatar[] @relation("AvatarFootwear")
  equippedAsHolding   Avatar[] @relation("AvatarHolding")

  owners UserItem[]

  @@index([typeId, sortOrder])
}

// Ownership pe iteme — proprietate persistata, separat de echipare. User-ul
// "detine" un item daca a fost (a) inserat la creare avatar default, (b)
// echipat manual la editorul de avatar, (c) primit ca non-duplicate dintr-un
// cufar deschis. Folosit pentru detectia duplicate la deschidere de cufar:
// daca item-ul rolat e deja in UserItem, devine "shards XP" in loc de drop.
model UserItem {
  id         String   @id @default(cuid())
  userId     String
  itemId     String
  acquiredAt DateTime @default(now())
  // 'default_avatar' (din PATCH /me/avatar), 'chest' (din openChest),
  // 'phone_down_winner' (viitor), 'seed' (backfill seed). String pt
  // flexibilitate; nu enum ca sa adaugam surse noi fara migrare.
  source     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

// Avatarul user-ului. Sursa de adevar = FK-urile per slot catre Item. `svg` e
// cache-ul renderat la save ca read-urile (lista prieteni, home) sa fie 1
// query fara DiceBear/composer. Toate cele 14 sloturi sunt obligatorii — "Fara"
// e item real cu feature=NULL (ramane FK valid).
model Avatar {
  id        String   @id @default(cuid())
  userId    String   @unique
  svg       String
  // Frame de blink: acelasi avatar cu ochii suprascrisi (variant22). Generat
  // odata cu `svg` la save. Nullable pentru avataruri create inainte de
  // animatii — se completeaza lazy la primul GET dupa deploy.
  svgBlink  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skinItemId      String
  hairColorItemId String
  hairItemId      String
  eyesItemId      String
  mouthItemId     String
  eyebrowsItemId  String
  glassesItemId   String
  earringsItemId  String
  featuresItemId  String
  bodyShapeItemId String
  topItemId       String
  outerwearItemId String
  bottomItemId    String
  footwearItemId  String
  holdingItemId   String

  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  skinItem      Item @relation("AvatarSkin", fields: [skinItemId], references: [id])
  hairColorItem Item @relation("AvatarHairColor", fields: [hairColorItemId], references: [id])
  hairItem      Item @relation("AvatarHair", fields: [hairItemId], references: [id])
  eyesItem      Item @relation("AvatarEyes", fields: [eyesItemId], references: [id])
  mouthItem     Item @relation("AvatarMouth", fields: [mouthItemId], references: [id])
  eyebrowsItem  Item @relation("AvatarEyebrows", fields: [eyebrowsItemId], references: [id])
  glassesItem   Item @relation("AvatarGlasses", fields: [glassesItemId], references: [id])
  earringsItem  Item @relation("AvatarEarrings", fields: [earringsItemId], references: [id])
  featuresItem  Item @relation("AvatarFeatures", fields: [featuresItemId], references: [id])
  bodyShapeItem Item @relation("AvatarBodyShape", fields: [bodyShapeItemId], references: [id])
  topItem       Item @relation("AvatarTop", fields: [topItemId], references: [id])
  outerwearItem Item @relation("AvatarOuterwear", fields: [outerwearItemId], references: [id])
  bottomItem    Item @relation("AvatarBottom", fields: [bottomItemId], references: [id])
  footwearItem  Item @relation("AvatarFootwear", fields: [footwearItemId], references: [id])
  holdingItem   Item @relation("AvatarHolding", fields: [holdingItemId], references: [id])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InteractionMethod {
  nfc
  ble
  manual
}

model Friendship {
  id           String             @id @default(cuid())
  requesterId  String
  receiverId   String
  status       FriendshipStatus   @default(PENDING)
  connectedVia InteractionMethod?
  createdAt    DateTime           @default(now())
  acceptedAt   DateTime?

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([receiverId, status])
  @@index([requesterId, status])
}

model DailyInteraction {
  id        String            @id @default(cuid())
  userId    String
  friendId  String
  date      DateTime          @db.Date
  method    InteractionMethod
  createdAt DateTime          @default(now())

  user   User @relation("InteractionUser", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("InteractionFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId, date])
  @@index([userId, date])
}

// Catalog de specii pentru pet-ul AI buddy. `voiceId` = identificator pentru
// TTS server-side (Microsoft Edge TTS pt MVP, voice clone post-MVP).
// `systemHint` se concateneaza la system prompt-ul AI ca pet-ul sa aiba
// personalitate distincta (ex: "ragusit, leneveste, da labute").
//
// `imagePath` = ruta relativa servita static la /pets/<file>.png (vizual la
// picioarele avatarului pe home). `tone`, `catchphrases`, `interests`,
// `shortLore` alimenteaza system prompt-ul AI buddy + sunt afisate user-ului
// in card-detail. `minAge` filtreaza speciile potrivite pt copilul curent;
// `unlockLevel` permite carduri "rare" deblocate la level mare.
model PetSpecies {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  voiceId          String
  systemHint       String
  isDefault        Boolean  @default(false)
  imagePath        String?
  shortLore        String   @default("")
  tone             String   @default("prietenos")
  catchphrases     String[] @default([])
  interests        String[] @default([])
  // Domenii de cultura generala in care specia "se pricepe" — match exact
  // pe HuntChallenge.domain. Cand un challenge are domain ∈ expertiseDomains
  // si specia e prezenta in party, pet-ul ofera hint subtil. Lista libera —
  // adaugare domeniu nou = UPDATE in DB.
  expertiseDomains String[] @default([])
  minAge           Int      @default(6)
  unlockLevel      Int      @default(1)
  // RVC voice conversion: URL la .zip cu .pth + .index (HuggingFace, voice-models.com).
  // Daca null → TTS-ul se livreaza direct, fara conversie. Daca setat → backendul
  // ruleaza pipeline 2-pasi (TTS romana → Replicate RVC) si livreaza vocea
  // personajului. Vezi lib/ai/voiceConvert.ts.
  rvcModelUrl      String?
  // Semitone shift aplicat in RVC. Pt voce grava (Vader) -3 / -4. Pt voce de
  // copil (Stitch) +2 / +3. 0 = fara shift.
  rvcPitchShift    Int      @default(0)
  // ElevenLabs voice id per specie (override la ELEVENLABS_VOICE_ID din env).
  // Cand setat, sintetiza folosind aceasta voce (chiar daca TTS_PROVIDER=edge
  // global). Util pt impersonari: Vader = voce dark masculine din Voice Library,
  // Stitch = voce expresiva, etc.
  elevenVoiceId    String?

  pets  Pet[]
  cards NfcPetCard[]
}

// Pet-ul fiecarui copil — agentul AI personalizat ECHIPAT. 1:1 cu User.
// `speciesId` = specia activa (poate fi schimbata cand user scaneaza alt card).
// `name` = nickname personalizat (default "Buddy", schimbat la primul card scanat
// sau de user). `bondXp` creste cu interactiunile (chat, prieteni, jocuri) —
// pet-ul "evolueaza" odata cu user-ul.
//
// Sursa de adevar pentru: AI buddy in stories, AI chat home, vizual la picioare.
model Pet {
  id        String   @id @default(cuid())
  userId    String   @unique
  speciesId String
  name      String   @default("Buddy")
  bondXp    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  species PetSpecies @relation(fields: [speciesId], references: [id])

  huntHints       HuntChallengeRun[]
  bondTransactions BondXpTransaction[]
}

// Acordare bond XP idempotenta — analog cu XpTransaction. Unicitate pe
// (petId, sourceType, sourceId) => acelasi run/event nu poate fi rasplatit
// de doua ori (re-engage / re-answer cu acelasi runId returneaza no-op).
model BondXpTransaction {
  id          String   @id @default(cuid())
  petId       String
  amount      Int
  sourceType  String
  sourceId    String?
  description String?
  createdAt   DateTime @default(now())

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@unique([petId, sourceType, sourceId])
  @@index([petId, createdAt])
}

// ===== STORY-ADVENTURE (joc: pet-ul te poarta printr-o lume pe o harta cu
// noduri + boss final, intrebari deghizate ca obstacole, deblochezi fundaluri).
//
// PRINCIPIU MODULAR: totul e data-driven. Adaugare lume noua / fundal nou =
// INSERT in DB, fara modificari de cod. `speciesSlug`, `domain`, `obstacleStyle`,
// paleta — string-uri libere. Generatorul AI citeste lumea + specia generic.

// O "lume" = harta tematica legata de o specie de pet + un domeniu de cunostinte.
// Un pet cu 2 expertiseDomains poate avea 2 lumi. Vizualul (paleta, stilul de
// obstacol) e stocat aici ca date, nu hardcodat in cod.
model AdventureWorld {
  id          String  @id @default(cuid())
  slug        String  @unique // ex. "groot-padure"
  speciesSlug String // legatura libera la PetSpecies.slug — fara FK ca sa ramana modular
  domain      String // domeniul intrebarilor (ex. "stiinte-naturii")
  name        String // ex. "Padurea Fermecata"
  lore        String  @default("") // descriere scurta de atmosfera
  bossName    String // ex. "Ursul Strabun"
  bossLore    String  @default("")
  nodeCount   Int     @default(4) // cate noduri de poveste inainte de boss
  // Config vizual ca date — UI-ul mobile mapeaza aceste chei la stiluri.
  // Adaugi un stil nou de obstacol = string nou aici + handling generic in UI.
  accentColor   String @default("#2ECC71")
  bgColor       String @default("#0E2A1A")
  obstacleStyle String @default("bridge") // "bridge" | "door" | "constellation" | ...
  active        Boolean @default(true)
  sortOrder     Int     @default(0)

  backgrounds ProfileBackground[]
  runs        AdventureRun[]

  @@index([speciesSlug, active])
}

// Un playthrough al unei lumi de catre un user. Continutul (poveste + checkpoint
// + intrebari boss) e generat O DATA de AI si cache-uit in `contentJson` ca
// refresh-ul sa nu regenereze. `answersJson` tine ce a raspuns (pt boss adaptive
// recall + acordare reward la final).
model AdventureRun {
  id        String   @id @default(cuid())
  userId    String
  worldSlug String
  status    String   @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | ABANDONED
  // Arcul generat de AI (capitole + obstacole + boss) ca JSON. Sursa de adevar
  // a continutului pe durata run-ului.
  contentJson  Json
  // Progres + raspunsuri: { nodeIndex, nodeAnswers: [{nodeId, correct}], bossDefeated }
  progressJson Json     @default("{}")
  startedAt    DateTime @default(now())
  completedAt  DateTime?

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  world AdventureWorld @relation(fields: [worldSlug], references: [slug])

  @@index([userId, status])
  @@index([userId, worldSlug])
}

// Fundal de profil deblocabil. STATIC — `imageUrl` populat manual de admin/user
// in DB. Legat de o lume; deblocat cand user-ul bate boss-ul lumii (eventual de
// `requiredCompletions` ori pt tier-uri superioare).
model ProfileBackground {
  id        String  @id @default(cuid())
  key       String  @unique // ex. "groot-padure-zori" sau "vader-ch2-nebula"
  // Legatura la o lume adventure — NULL pentru fundalurile din journey (care
  // se deblocheaza la checkpoint, nu prin AdventureWorld). Decuplat ca journey
  // sa fie modular independent de adventure.
  worldSlug String?
  // Pet-ul (specia) careia ii apartine fundalul — folosit de journey ca sa
  // afiseze fundalurile in ordine. Liber, fara FK.
  petSlug   String?
  name      String
  imageUrl  String // populat de user; static
  tier      Int     @default(1) // 1=bronze, 2=argint, 3=aur — pt extindere viitoare
  requiredCompletions Int @default(1) // cate victorii la boss ca sa deblochezi (adventure)
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  world    AdventureWorld?  @relation(fields: [worldSlug], references: [slug])
  unlocks  UserBackground[]

  @@index([worldSlug, active])
  @@index([petSlug, active])
}

// Deblocare fundal de catre user — idempotent prin unique (userId, backgroundKey).
model UserBackground {
  id            String   @id @default(cuid())
  userId        String
  backgroundKey String
  unlockedAt    DateTime @default(now())

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  background ProfileBackground @relation(fields: [backgroundKey], references: [key], onDelete: Cascade)

  @@unique([userId, backgroundKey])
  @@index([userId])
}

// Progresul povestilor Journey per user. Cand user-ul termina un capitol (atinge
// scena checkpoint), salvam aici intrarea. Mobile cere progresul la deschiderea
// chat-ului ca sa stie daca sa propuna aventura sau nu. Unique pe (userId,
// chapterId) → idempotent.
model JourneyChapterProgress {
  id          String   @id @default(cuid())
  userId      String
  // chapterId din mobile (ex: 'vader-ch1'). Nu legam de model in DB pt
  // modularitate — capitolele sunt definite in mobile.
  chapterId   String
  // Slug pet la momentul completarii — util pt grupare per pet.
  petSlug     String
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId, petSlug])
}

// Pool global de intrebari de cultura generala pentru jocul Journey.
// Mobile cere random N intrebari per `domain` la inceputul fiecarui capitol,
// filtrate dupa varsta copilului. Asa fiecare playthrough are alta combinatie
// si copiii nu pot impartasi raspunsurile.
//
// Adaugare intrebare noua = INSERT in DB (manual sau prin script). Bazele
// mari (sute) → sanse minime de overlap intre copii.
model JourneyQuestion {
  id           String   @id @default(cuid())
  // Domeniul tematic: 'spatiu' | 'ocean' | 'padure' | 'desert' | 'oras' |
  // 'general'. Trebuie sa coincida cu domain-urile setate pe scene challenge.
  domain       String
  // Interval varsta tinta (ani). Copilul cu varsta in [minAge, maxAge]
  // primeste intrebarea. Calculam varsta din User.birthDate.
  minAge       Int      @default(6)
  maxAge       Int      @default(14)
  prompt       String   // intrebarea pe care o citeste pet-ul
  options      String[] // 2-4 optiuni
  correctIndex Int      // index 0-based al optiunii corecte
  successLine  String   @default("Asa este!") // reactia pet la corect
  failLine     String   @default("Nu chiar, dar e bine ca incercam.") // reactia la gresit
  // Explicatie scurta citita de narator DUPA reactia pet-ului (atat la
  // corect, cat si la gresit). Intareste cunostinta cu o curiozitate. Optional.
  explanation  String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([domain, active])
}

// Card NFC fizic colectabil. UID-ul e hardcodat de fabrica si unic global.
// Cand un user scaneaza un card neclamat, devine ownerId. Re-scan = doar
// equip (Pet.speciesId schimbat la specia cardului). Un user are O colectie
// (multe carduri), dar o SINGURA specie activa pe Pet la un moment dat.
//
// `nickname` = numele dat de user acelui card specific (ramane chiar daca
// nu e echipat). La equip, Pet.name se sincronizeaza cu nickname-ul (sau
// numele speciei daca null).
model NfcPetCard {
  id        String    @id @default(cuid())
  uid       String    @unique
  speciesId String
  ownerId   String?
  nickname  String?
  claimedAt DateTime?
  createdAt DateTime  @default(now())

  species PetSpecies @relation(fields: [speciesId], references: [id])
  owner   User?      @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([ownerId])
}

// Poveste creata de copil impreuna cu pet-ul (chat conversational, 1/zi/copil).
// `body` e textul integral — vizibil DOAR autorului prin /stories/mine.
// `keyFacts` e secret server-side: lista [{q, expected}] folosita ca cheie de
// validare in chat-ul de verify (B nu vede niciodata textul si nici keyFacts).
//
// Lant de povesti: dupa ce un prieten verifica o poveste (StoryClaim VERIFIED)
// poate sa o EXTINDA cu propriul capitol — devine un Story nou cu
// `parentStoryId` setat la povestea ascultata. `chainRootId` denormalizeaza
// radacina lantului (pt query rapid "toate capitolele lantului") — la
// originalul lantului egal cu propriul id.
//
// keyFacts pe extensie sunt CUMULATIVE: AI le emite acoperind tot lantul
// pana la capitolul curent inclusiv (ca la retelling B povesteste lui C
// intregul fir). audioUrl/audioProvider salveaza mp3-ul TTS al propriului
// capitol (pentru audiobook-ul lantului = secventa de capitole).
model Story {
  id            String   @id @default(cuid())
  authorId      String
  title         String
  body          String
  keyFacts      Json
  parentStoryId String?
  chainRootId   String?
  audioUrl      String?
  audioProvider String?
  createdAt     DateTime @default(now())

  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent      Story?       @relation("StoryChain", fields: [parentStoryId], references: [id], onDelete: SetNull)
  children    Story[]      @relation("StoryChain")
  claims      StoryClaim[]
  coCreations CoCreation[]

  @@index([authorId, createdAt])
  @@index([chainRootId])
  @@index([parentStoryId])
}

enum StoryClaimStatus {
  ATTEMPTING
  VERIFIED
  FAILED
}

// Tentativa lui B de a-si valida ca i-a fost spusa povestea. Unique
// (storyId, listenerId) = max 1 inregistrare per pereche; campul `score`
// retine cate raspunsuri din keyFacts au trecut grading-ul AI. 2 incercari
// permise (typo-forgiveness) inainte de FAILED — gestionat in handler.
model StoryClaim {
  id         String           @id @default(cuid())
  storyId    String
  listenerId String
  status     StoryClaimStatus @default(ATTEMPTING)
  startedAt  DateTime         @default(now())
  verifiedAt DateTime?
  attempts   Int              @default(0)
  score      Int?
  answers    Json?

  story    Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  listener User  @relation(fields: [listenerId], references: [id], onDelete: Cascade)

  @@unique([storyId, listenerId])
  @@index([listenerId, status])
}

// Sesiune de co-creatie: doi copii fizic impreuna aleg o poveste (a unuia
// dintre ei) si deseneaza pe hartie. Submit poza desenului → Claude vision
// valideaza ca match-uieste scena povestii si ca e potrivit varstei. Daca
// trece, Vertex AI Imagen genereaza o ilustratie digitala "transpusa" inspirata
// din desen + povestire. Album entry vizibil ambilor.
//
// userA  = initiatorul (cel care a pornit sesiunea, scaneaza NFC).
// userB  = celalalt copil (NFC tag scanat).
// storyId = una din povestile lui userA SAU userB (validat la /start).
// expiresAt = startedAt + 30min; dupa, /submit refuza si seteaza EXPIRED.
// originalImageKey/aiImageKey = chei GCS, signed URLs generate la GET.
enum CoCreationStatus {
  ACTIVE // start trimis, asteapta submit poza
  PROCESSING // poza primita, ruleaza validare + image gen async
  COMPLETED // valid + AI image gata, aparut in album
  REJECTED // AI a refuzat (off-topic / continut nepotrivit)
  EXPIRED // 30 min fara submit
  FAILED // eroare interna pipeline (Imagen / GCS down)
}

// Cum s-a alaturat userB sesiunii — relevant pt audit + lucrare licenta.
// NFC_BAND  = host a scanat bratara NFC a partenerului (cazul cand B nu are
//             telefon, sau e iPhone si nu poate fi scanat peer-to-peer).
// NFC_PHONE = host a scanat telefonul partenerului (Android HCE, planificat
//             in Iteratia 2 — adaugat acum ca migrarea sa fie one-shot).
enum CoCreationJoinMethod {
  NFC_BAND
  NFC_PHONE
}

model CoCreation {
  id               String               @id @default(cuid())
  userAId          String
  userBId          String
  storyId          String
  startedAt        DateTime             @default(now())
  expiresAt        DateTime
  submittedById    String?
  submittedAt      DateTime?
  originalImageKey String?
  aiImageKey       String?
  aiValid          Boolean?
  aiFeedback       String?
  status           CoCreationStatus     @default(ACTIVE)
  joinMethod       CoCreationJoinMethod @default(NFC_BAND)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  userA User  @relation("CoCreationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User  @relation("CoCreationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([userAId, status])
  @@index([userBId, status])
  @@index([storyId])
}

// ===== HUNT (treasure hunt cu echipe in parcuri) =====
//
// Park = cache pentru poligoanele OSM (leisure=park). Re-fetch saptamanal
// pentru parcuri active (lastFetchedAt < 7 zile). polygon e GeoJSON
// stocat ca string pt portabilitate (Postgres are PostGIS dar nu vrem
// dependinta extra pt MVP — turf.js face calcule client-server in JS).
model Park {
  id            String   @id @default(cuid())
  // Identificator OSM (way/12345 sau relation/67890). Unique pe el ca
  // sa de-duplicam la re-fetch.
  osmId         String   @unique
  name          String
  // GeoJSON Polygon sau MultiPolygon stringified. Calculele de zona si
  // contains se fac in JS via turf.
  polygon       String
  // Bounding box cache pt query rapid de proximitate (filtru initial in DB
  // inainte de turf.distance pe lista filtrata).
  bboxMinLat    Float
  bboxMaxLat    Float
  bboxMinLng    Float
  bboxMaxLng    Float
  // m^2 calculat la salvare; folosit la spawn density si la filtru "parc
  // prea mic pentru hunt cu mai multe echipe".
  areaSqm       Float
  city          String?
  lastFetchedAt DateTime @default(now())
  createdAt     DateTime @default(now())

  sessions HuntSession[]

  @@index([bboxMinLat, bboxMaxLat])
  @@index([bboxMinLng, bboxMaxLng])
}

// Bestiar static — sursa de adevar pentru ce monstri pot aparea in hunt.
// Spawn-ul citeste din acest tabel filtrand pe tier (green/yellow/red/gold).
// `domain` = axa de cultura generala (geografie, istorie, stiinte-naturii...)
// si determina pool-ul de intrebari trase la engage + ce pet din party poate
// soptesste hint (cel cu `domain` ∈ expertiseDomains).
// `difficulty` 1-3 = dificultatea intrebarilor preferate; in general
// corelata cu tier dar setabila separat.
// Adaugare monstru nou = INSERT in DB, fara modificari de cod.
model MonsterTemplate {
  id         String      @id @default(cuid())
  slug       String      @unique
  name       String
  domain     String
  difficulty Int         @default(1)
  tier       MonsterType
  loreShort  String      @default("")
  imagePath  String?
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())

  @@index([active, tier])
  @@index([domain])
}

// Bank global de challenge-uri. `domain` = subiect canonic (geografie,
// istorie, stiinte-naturii...) folosit pentru match pe MonsterTemplate.domain
// si pentru hint-ul pet-ului. `themeTags` ramane aroma fina opt (ex: "apa",
// "dinozauri") fara legatura cu tema parcului.
enum ChallengeType {
  mcq // grila cu 4 variante, comparatie text exact
  riddle // text liber, deprecated — pastrat pt compat istoric
  photo // user trimite foto, validat de Claude vision (TBD)
  counting // numarare obiect din mediu, tap pe ecran
}

model HuntChallenge {
  id         String        @id @default(cuid())
  // Slug stabil pentru seed idempotent — re-rularea seed-ului doar updateaza
  // prompt/expected, nu creeaza duplicate.
  slug       String        @unique
  type       ChallengeType
  prompt     String // text afisat copilului
  // mcq: "expected" e textul variantei corecte (matchuit exact din options);
  // riddle: "expected" e raspunsul corect (legacy, semantic match);
  // photo: "expected" e descrierea a ce trebuie sa apara in poza;
  // counting: "expected" e numarul int (stocat ca string).
  expected   String
  // mcq: pipe-delimited "var1|var2|var3|var4" (4 variante, una egala cu expected).
  // Nullabil pt compat cu celelalte tipuri.
  options    String?
  // Praguri de varsta — selector ia dupa birthDate. Inclusiv-inclusiv.
  ageMin     Int
  ageMax     Int
  // Subiect canonic (geografie, istorie, stiinte-naturii, fizica-chimie,
  // spatiu, corp-uman, limba-romana, literatura, arta-muzica, matematica,
  // tehnologie, viata-cotidiana). Match exact pe MonsterTemplate.domain la
  // engage si pe PetSpecies.expertiseDomains la hint. Adaugare domeniu nou
  // = doar INSERT cu domain="...", fara cod atins.
  domain     String        @default("")
  // Aroma fina optionala (ex: "apa", "dinozauri", "razboi-mondial"). Nu
  // afecteaza matching-ul principal — folosit doar pt filtre fine la nevoie.
  themeTags  String        @default("")
  difficulty Int           @default(1) // 1=usor, 2=mediu, 3=greu
  active     Boolean       @default(true)
  createdAt  DateTime      @default(now())

  runs HuntChallengeRun[]

  @@index([type, ageMin, ageMax, active])
  @@index([domain, difficulty, active])
}

enum HuntStatus {
  LOBBY // host a creat, asteapta alti membri sa accepte (sau auto-pornire)
  ACTIVE // gameplay in progres
  COMPLETED // timeout sau host a apasat end
  CANCELLED // criterii ne-indeplinite (echipe rupte etc.)
}

model HuntSession {
  id           String     @id @default(cuid())
  hostId       String
  parkId       String
  status       HuntStatus @default(LOBBY)
  durationSec  Int // 900 / 1800 / 2700 (15 / 30 / 45 min)
  startedAt    DateTime?
  endsAt       DateTime? // startedAt + durationSec
  endedAt      DateTime?
  // Cache: numar total de monstri spawn-ati la pornire, pentru progress UI.
  monsterCount Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  host     User              @relation("HuntHost", fields: [hostId], references: [id], onDelete: Cascade)
  park     Park              @relation(fields: [parkId], references: [id])
  teams    HuntTeam[]
  monsters HuntMonster[]
  lobby    HuntLobbyMember[]

  @@index([hostId, status])
  @@index([status, endsAt])
}

// Participant in stagiul LOBBY — inainte ca host-ul sa apese start si echipele
// sa fie generate. La pornire, lobby members sunt convertiti in HuntTeamMember
// random + lobby-ul se goleste. Permite drop in/out flexibil pre-start.
model HuntLobbyMember {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  joinedAt  DateTime @default(now())

  session HuntSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId])
}

model HuntTeam {
  id               String   @id @default(cuid())
  sessionId        String
  // Liderul echipei (ales aleatoriu la Start dintre membri). Doar el joaca
  // efectiv pe telefonul lui — restul echipei sta langa el fizic.
  leaderId         String?
  name             String // "Lac" / "Padure" / sau "Echipa 1" — default pana liderul il schimba
  // Liderul confirma/schimba numele inainte sa apara AR-ul. Pana atunci
  // membrii vad "asteptam pe lider sa numeasca echipa".
  nameSet          Boolean  @default(false)
  // GeoJSON Polygon — sub-zona din parc atribuita echipei. Calculat la
  // pornire prin turf intersection (bbox stripes ∩ park polygon).
  zone             String
  zoneArea         Float // m^2
  // Scor cumulativ in sesiune. Update incremental la fiecare monstru ucis,
  // ca polling-ul de scoreboard sa fie 1 SELECT.
  score            Int      @default(0)
  monstersDefeated Int      @default(0)
  createdAt        DateTime @default(now())

  session  HuntSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  members  HuntTeamMember[]
  monsters HuntMonster[]
  defeats  HuntMonsterDefeat[]

  @@index([sessionId])
}

model HuntTeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  joinedAt DateTime @default(now())

  team HuntTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

enum MonsterType {
  green // 50 puncte, 1 challenge per teammate
  yellow // 150 puncte, 2 challenge per teammate
  red // 400 puncte, 3 challenge per teammate
  gold // 1000 puncte, rar, 1 challenge dificil per teammate, time-limited spawn
}

enum MonsterStatus {
  HIDDEN // pe harta, nedescoperit inca
  ENGAGED // o echipa l-a descoperit si a pornit lupta
  DEFEATED // ucis cu succes
  ESCAPED // timer expirat sau toate challenges esuate
}

model HuntMonster {
  id        String        @id @default(cuid())
  sessionId String
  // Echipa careia ii apartine (zona ei). NULL inseamna ca nu e atribuit (eroare)
  // — in practica setat la spawn.
  teamId    String?
  type      MonsterType
  // Slug-ul si meta cache-uite din MonsterTemplate (e.g. "spirit-lac") la
  // spawn — pastrate denormalizat pe monstru sa nu necesite join la query.
  slug      String
  name      String
  loreShort String
  // Pozitie GPS spawn (validata sa fie in zona team-ului).
  lat       Float
  lng       Float
  status    MonsterStatus @default(HIDDEN)
  // Timestamp engaged — fereastra de 90 sec pentru completion.
  engagedAt DateTime?
  expiresAt DateTime?
  createdAt DateTime      @default(now())

  session HuntSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  team    HuntTeam?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  runs    HuntChallengeRun[]
  defeat  HuntMonsterDefeat?

  @@index([sessionId, teamId, status])
}

// Challenge alocat unui (monster, user) specific. La engage, generam N runs
// pe membru ai echipei (1/2/3 dupa type). User raspunde, evaluator (Claude
// pentru riddle/photo, comparator simplu pentru counting) seteaza outcome.
enum ChallengeOutcome {
  PENDING
  CORRECT
  WRONG
  SKIPPED // user a renuntat / timeout
}

model HuntChallengeRun {
  id           String           @id @default(cuid())
  monsterId    String
  userId       String
  challengeId  String
  outcome      ChallengeOutcome @default(PENDING)
  // Raspunsul brut (text / photoKey GCS / numar). Salvat pentru audit + AI
  // scoring asincron.
  answer       String?
  // Feedback scurt de la Claude pentru riddle/photo ("aproape, era X").
  feedback     String?
  // Hint subtil generat la engage de pet-ul unui coleg din party care are
  // domain-ul intrebarii in expertiseDomains. NULL daca niciun pet din echipa
  // nu match-uieste. Idempotent — generat o singura data per run.
  petHint      String?
  // FK la Pet-ul care a "soptit" — pt UI ("Buddy al lui Maria iti spune..."
  // si pt atribuirea avatarului in chenarul de hint).
  petHintPetId String?
  startedAt    DateTime         @default(now())
  finishedAt   DateTime?

  monster    HuntMonster   @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge  HuntChallenge @relation(fields: [challengeId], references: [id])
  petHintPet Pet?          @relation(fields: [petHintPetId], references: [id], onDelete: SetNull)

  @@unique([monsterId, userId, challengeId])
  @@index([monsterId, outcome])
}

// Audit log pe fiecare monstru ucis cu succes — pt scoreboard final si stats.
// Idempotent prin (monsterId) unique: max 1 record per monstru.
model HuntMonsterDefeat {
  id            String   @id @default(cuid())
  monsterId     String   @unique
  teamId        String
  pointsAwarded Int
  durationMs    Int // cat a durat lupta
  defeatedAt    DateTime @default(now())

  monster HuntMonster @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  team    HuntTeam    @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model XpTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  sourceType  String
  sourceId    String?
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, sourceId])
  @@index([userId, createdAt])
}

// ===== PHONE DOWN (concurs "cine rezista cel mai mult fara sa atinga
// telefonul"). BLE e folosit doar pentru a invita prietenii din raza in
// lobby; dupa start fiecare device joaca independent, server-ul tine
// clasamentul si emite events prin socket.
//
// Cap silentios 4h: peste atat sesiunea se inchide automat (anti "am uitat
// telefonul jos"). Sub 5 min jucate = niciun cufar (anti farm).

enum PhoneDownStatus {
  WAITING // lobby deschis, host astepta join-uri (fereastra 30s)
  PLAYING // runda activa, participantii cu telefonul jos
  ENDED // toti au cedat sau cap-ul de 4h s-a atins
  CANCELLED // host a anulat lobby-ul inainte de start
}

enum PhoneDownParticipantStatus {
  ACTIVE // telefon jos, in concurs
  PAUSED // apel telefonic in curs, timer-ul ingheata
  SURRENDERED // a atins telefonul → eliminat
  WINNER // ultimul ramas activ la final
}

model PhoneDownSession {
  id        String          @id @default(cuid())
  hostId    String
  status    PhoneDownStatus @default(WAITING)
  // Timestamp cand host a apasat Start (toti participantii incep countdown-ul
  // de 5s in acelasi moment). NULL cat e WAITING.
  startedAt DateTime?
  // Cap silentios = startedAt + 4h. Server-ul forteaza ENDED la atingere.
  capAt     DateTime?
  endedAt   DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  host         User                   @relation("PhoneDownHost", fields: [hostId], references: [id], onDelete: Cascade)
  participants PhoneDownParticipant[]

  @@index([hostId, status])
  @@index([status, capAt])
}

model PhoneDownParticipant {
  id            String                     @id @default(cuid())
  sessionId     String
  userId        String
  status        PhoneDownParticipantStatus @default(ACTIVE)
  joinedAt      DateTime                   @default(now())
  // Timestamp efectiv cand a pus telefonul jos (dupa countdown-ul de 5s).
  // Toti participantii o au aproximativ identica = session.startedAt + 5s.
  phoneDownAt   DateTime?
  // Timestamp cand a atins/unlock-uit telefonul. NULL daca inca rezista.
  surrenderedAt DateTime?
  // Cumulativ timp petrecut in pauza (apel telefonic). Scaderea din durata
  // efectiva la calcul: durationMs = (surrenderedAt - phoneDownAt) - pausedAccumMs.
  pausedAccumMs Int                        @default(0)
  // Timestamp cand a inceput pauza curenta. NULL daca nu e in pauza acum.
  pausedAt      DateTime?
  // Atribuite la sfarsit (1 = ultimul ramas activ, N = primul cedat).
  rank          Int?
  // Durata efectiva fara pauze. Cache la closure ca sa nu recalculam la fiecare GET.
  durationMs    Int?
  chestId       String?                    @unique

  session PhoneDownSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chest   Chest?           @relation(fields: [chestId], references: [id])

  @@unique([sessionId, userId])
  @@index([userId, status])
  @@index([sessionId, status])
}

// Cufere obtinute din PhoneDown (si surse viitoare). Cand sunt create,
// continutul e PRE-ROLAT in lootJson — deschiderea e doar revealing
// (anti save-scum prin restart app). User-ul poate strange cufere si le
// deschide cand vrea.
enum ChestTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  CHAMPION // dedicat castigatorului PhoneDown (#1), loot exclusiv legendary
}

model Chest {
  id         String    @id @default(cuid())
  userId     String
  tier       ChestTier
  // Sursa: "phone_down" pt MVP. Las string ca sa adaug viitoare (treasure_hunt,
  // story_chain, etc.) fara migrare.
  sourceType String
  sourceId   String?
  // Continut pre-rolat: { xp: number, items: [{ itemId, slug, name, rarity }],
  // duplicates: [{ slug, shardsXp: number }] }. Stocat ca JSON pentru
  // flexibilitate de schema viitoare.
  lootJson   Json
  openedAt   DateTime?
  createdAt  DateTime  @default(now())

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  participant PhoneDownParticipant?

  @@index([userId, openedAt])
}

// Configurari per ChestTier — pragul minim de durata, cate iteme pica, XP de
// baza, ponderi pentru drop weighted, si tier-ul de upgrade pentru castigator.
// Editat doar din seed (sau direct in DB). Permite ajustari de game balance
// fara redeploy.
model ChestTierConfig {
  tier                ChestTier  @id
  // Durata minima (ms) jucat efectiv pentru a primi acest tier. Tier-ul atribuit
  // = cel mai mare cu minDurationMs <= durationMs.
  minDurationMs       Int
  // Cate iteme pica in cufar (in afara de XP).
  itemCount           Int
  xpBase              Int
  // Ponderi pentru rolling rarity (suma > 0 daca tier-ul e dropable; toate 0 +
  // guaranteed*>0 → loot complet deterministic, ca CHAMPION).
  weightCommon        Int        @default(0)
  weightRare          Int        @default(0)
  weightEpic          Int        @default(0)
  weightLegendary     Int        @default(0)
  // Daca user-ul a castigat (#1) cu acest tier de baza, primeste in schimb
  // tier-ul de upgrade. NULL = nu se upgradeaza (CHAMPION e top).
  upgradeToTier       ChestTier?
  // Loot garantat (in afara rolling-ului). Pentru CHAMPION: 1 legendary + 1 epic.
  // Daca >0, primele N iteme sunt selectate direct din pool-ul de raritatea
  // respectiva; restul (itemCount - guaranteed) sunt rolled prin weights.
  guaranteedLegendary Int        @default(0)
  guaranteedEpic      Int        @default(0)
  // Sansa (0-100) ca un slot ne-garantat sa scoata efectiv un item. La 100
  // (default) primesti garantat `itemCount` iteme. La 30 doar ~30% din
  // sloturi vor avea item. Slot-urile garantate (guaranteed*) NU sunt
  // supuse acestei sanse — ele pica mereu.
  itemDropChance      Int        @default(100)

  // Vizual config — alimenteaza UI-ul de pe mobil fara hardcoded TIER_COLORS.
  // Adaugare tier nou = INSERT row aici + 3 SVG-uri in assets/chests/.
  label       String? // ex. "Bronz", "Argint" (RO, afisat in card)
  sortOrder   Int     @default(0)
  bgColor     String? // backgroundul tile-ului de loot
  darkColor   String? // border/shadow
  fgColor     String? // text color pe bg
  glowColor   String? // burst ring + light rays
  // Path-uri relative din backend/assets/chests/ — seed citeste fisierele si
  // copiaza continutul SVG inline in mobile response (la endpoint
  // GET /chests/tiers). User-ul poate edita fisierele si re-rula seed.
  miniSvgPath String?
  bodySvgPath String?
  lidSvgPath  String?
  // Continutul SVG cache-uit dupa citirea fisierelor (sursa de adevar runtime).
  // NULL pana la prima rulare a seed-ului dupa migratia visuals.
  miniSvg     String?
  bodySvg     String?
  lidSvg      String?
}

// XP bonus la deschidere pentru fiecare item duplicat (shards). Mai rar = mai
// dureros sa-l vezi duplicat → bonus mai mare.
model RarityDuplicateXp {
  rarity Rarity @id
  xp     Int
}
