// Schema incrementala. Modele viitoare planificate:
// Avatar + AvatarItem, GameSession + rounds/answers, PetSpecies + NfcCard + UserPet,
// Achievements. Le adaugam pe masura ce construim feature-urile.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  birthDate    DateTime
  xp           Int      @default(0)
  level        Int      @default(1)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  friendshipsSent     Friendship[]      @relation("FriendshipRequester")
  friendshipsReceived Friendship[]      @relation("FriendshipReceiver")
  interactionsAsA     DailyInteraction[] @relation("InteractionUser")
  interactionsAsB     DailyInteraction[] @relation("InteractionFriend")
  xpTransactions      XpTransaction[]
  avatar              Avatar?
  bracelet            NfcBracelet?
  pet                 Pet?
  stories             Story[]
  storyClaims         StoryClaim[]
  coCreationsAsA      CoCreation[]      @relation("CoCreationUserA")
  coCreationsAsB      CoCreation[]      @relation("CoCreationUserB")

  @@index([email])
}

// Legare cont <-> bratara NFC. UID-ul tag-ului (hardcodat de fabrica, citit la
// scanare) e unic per user. MVP: o bratara per cont; re-provisioning-ul
// suprascrie inregistrarea existenta.
model NfcBracelet {
  id            String   @id @default(cuid())
  uid           String   @unique
  userId        String   @unique
  provisionedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Catalogul de iteme. ItemType = slotul (skin, hair, top...), Item = optiunea
// concreta (skin-02 "Nisip"). Datele sunt seed-uite din prisma/seed.ts. Slug-ul
// e identificatorul stabil folosit in API-ul cu mobile (mobile trimite "skin-02",
// backend rezolva la id intern).
// `group` separa tab-urile mari din editor: "face" (ten, par, ochi...) vs
// "body" (top, pantaloni, ghete...). Stocat ca string nu enum ca sa adaugam
// usor grupuri noi (ex: "accessories") fara migrare de schema.
model ItemType {
  id        String @id @default(cuid())
  slug      String @unique
  name      String
  group     String
  sortOrder Int    @default(0)

  items Item[]
}

model Item {
  id        String  @id @default(cuid())
  typeId    String
  slug      String  @unique
  name      String
  // Codul de redare folosit de DiceBear / body composer. NULL = "fara"
  // (ochelari, cercei, vesta, holding) — opt-out explicit, item real in catalog.
  feature   String?
  level     Int     @default(1)
  sortOrder Int     @default(0)

  type ItemType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  // Echipari per slot — cate o relatie nominala pentru fiecare FK pe Avatar,
  // ca Prisma sa stie sa reverse-lookup-uiasca corect.
  equippedAsSkin      Avatar[] @relation("AvatarSkin")
  equippedAsHairColor Avatar[] @relation("AvatarHairColor")
  equippedAsHair      Avatar[] @relation("AvatarHair")
  equippedAsEyes      Avatar[] @relation("AvatarEyes")
  equippedAsMouth     Avatar[] @relation("AvatarMouth")
  equippedAsEyebrows  Avatar[] @relation("AvatarEyebrows")
  equippedAsGlasses   Avatar[] @relation("AvatarGlasses")
  equippedAsEarrings  Avatar[] @relation("AvatarEarrings")
  equippedAsBodyShape Avatar[] @relation("AvatarBodyShape")
  equippedAsTop       Avatar[] @relation("AvatarTop")
  equippedAsOuterwear Avatar[] @relation("AvatarOuterwear")
  equippedAsBottom    Avatar[] @relation("AvatarBottom")
  equippedAsFootwear  Avatar[] @relation("AvatarFootwear")
  equippedAsHolding   Avatar[] @relation("AvatarHolding")

  @@index([typeId, sortOrder])
}

// Avatarul user-ului. Sursa de adevar = FK-urile per slot catre Item. `svg` e
// cache-ul renderat la save ca read-urile (lista prieteni, home) sa fie 1
// query fara DiceBear/composer. Toate cele 14 sloturi sunt obligatorii — "Fara"
// e item real cu feature=NULL (ramane FK valid).
model Avatar {
  id        String   @id @default(cuid())
  userId    String   @unique
  svg       String
  // Frame de blink: acelasi avatar cu ochii suprascrisi (variant22). Generat
  // odata cu `svg` la save. Nullable pentru avataruri create inainte de
  // animatii — se completeaza lazy la primul GET dupa deploy.
  svgBlink  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skinItemId      String
  hairColorItemId String
  hairItemId      String
  eyesItemId      String
  mouthItemId     String
  eyebrowsItemId  String
  glassesItemId   String
  earringsItemId  String
  bodyShapeItemId String
  topItemId       String
  outerwearItemId String
  bottomItemId    String
  footwearItemId  String
  holdingItemId   String

  user          User @relation(fields: [userId],          references: [id], onDelete: Cascade)
  skinItem      Item @relation("AvatarSkin",      fields: [skinItemId],      references: [id])
  hairColorItem Item @relation("AvatarHairColor", fields: [hairColorItemId], references: [id])
  hairItem      Item @relation("AvatarHair",      fields: [hairItemId],      references: [id])
  eyesItem      Item @relation("AvatarEyes",      fields: [eyesItemId],      references: [id])
  mouthItem     Item @relation("AvatarMouth",     fields: [mouthItemId],     references: [id])
  eyebrowsItem  Item @relation("AvatarEyebrows",  fields: [eyebrowsItemId],  references: [id])
  glassesItem   Item @relation("AvatarGlasses",   fields: [glassesItemId],   references: [id])
  earringsItem  Item @relation("AvatarEarrings",  fields: [earringsItemId],  references: [id])
  bodyShapeItem Item @relation("AvatarBodyShape", fields: [bodyShapeItemId], references: [id])
  topItem       Item @relation("AvatarTop",       fields: [topItemId],       references: [id])
  outerwearItem Item @relation("AvatarOuterwear", fields: [outerwearItemId], references: [id])
  bottomItem    Item @relation("AvatarBottom",    fields: [bottomItemId],    references: [id])
  footwearItem  Item @relation("AvatarFootwear", fields: [footwearItemId],  references: [id])
  holdingItem   Item @relation("AvatarHolding",   fields: [holdingItemId],   references: [id])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InteractionMethod {
  nfc
  ble
  manual
}

model Friendship {
  id            String            @id @default(cuid())
  requesterId   String
  receiverId    String
  status        FriendshipStatus  @default(PENDING)
  connectedVia  InteractionMethod?
  createdAt     DateTime          @default(now())
  acceptedAt    DateTime?

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([receiverId, status])
  @@index([requesterId, status])
}

model DailyInteraction {
  id        String            @id @default(cuid())
  userId    String
  friendId  String
  date      DateTime          @db.Date
  method    InteractionMethod
  createdAt DateTime          @default(now())

  user   User @relation("InteractionUser",   fields: [userId],   references: [id], onDelete: Cascade)
  friend User @relation("InteractionFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId, date])
  @@index([userId, date])
}

// Catalog de specii pentru pet-ul AI buddy. `voiceId` = identificator pentru
// TTS server-side (Microsoft Edge TTS pt MVP, voice clone post-MVP).
// `systemHint` se concateneaza la system prompt-ul AI ca pet-ul sa aiba
// personalitate distincta (ex: "ragusit, leneveste, da labute").
model PetSpecies {
  id         String  @id @default(cuid())
  slug       String  @unique
  name       String
  voiceId    String
  systemHint String
  isDefault  Boolean @default(false)

  pets Pet[]
}

// Pet-ul fiecarui copil — agentul AI personalizat. Cream lazy la register cu
// `species = default` (caine "Buddy"). Personalizare specie/nume in iteratia 2.
model Pet {
  id        String   @id @default(cuid())
  userId    String   @unique
  speciesId String
  name      String   @default("Buddy")
  createdAt DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  species PetSpecies @relation(fields: [speciesId], references: [id])
}

// Poveste creata de copil impreuna cu pet-ul (chat conversational, 1/zi/copil).
// `body` e textul integral — vizibil DOAR autorului prin /stories/mine.
// `keyFacts` e secret server-side: lista [{q, expected}] folosita ca cheie de
// validare in chat-ul de verify (B nu vede niciodata textul si nici keyFacts).
//
// Lant de povesti: dupa ce un prieten verifica o poveste (StoryClaim VERIFIED)
// poate sa o EXTINDA cu propriul capitol — devine un Story nou cu
// `parentStoryId` setat la povestea ascultata. `chainRootId` denormalizeaza
// radacina lantului (pt query rapid "toate capitolele lantului") — la
// originalul lantului egal cu propriul id.
//
// keyFacts pe extensie sunt CUMULATIVE: AI le emite acoperind tot lantul
// pana la capitolul curent inclusiv (ca la retelling B povesteste lui C
// intregul fir). audioUrl/audioProvider salveaza mp3-ul TTS al propriului
// capitol (pentru audiobook-ul lantului = secventa de capitole).
model Story {
  id              String   @id @default(cuid())
  authorId        String
  title           String
  body            String
  keyFacts        Json
  parentStoryId   String?
  chainRootId     String?
  audioUrl        String?
  audioProvider   String?
  createdAt       DateTime @default(now())

  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent      Story?       @relation("StoryChain", fields: [parentStoryId], references: [id], onDelete: SetNull)
  children    Story[]      @relation("StoryChain")
  claims      StoryClaim[]
  coCreations CoCreation[]

  @@index([authorId, createdAt])
  @@index([chainRootId])
  @@index([parentStoryId])
}

enum StoryClaimStatus {
  ATTEMPTING
  VERIFIED
  FAILED
}

// Tentativa lui B de a-si valida ca i-a fost spusa povestea. Unique
// (storyId, listenerId) = max 1 inregistrare per pereche; campul `score`
// retine cate raspunsuri din keyFacts au trecut grading-ul AI. 2 incercari
// permise (typo-forgiveness) inainte de FAILED — gestionat in handler.
model StoryClaim {
  id         String           @id @default(cuid())
  storyId    String
  listenerId String
  status     StoryClaimStatus @default(ATTEMPTING)
  startedAt  DateTime         @default(now())
  verifiedAt DateTime?
  attempts   Int              @default(0)
  score      Int?
  answers    Json?

  story    Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  listener User  @relation(fields: [listenerId], references: [id], onDelete: Cascade)

  @@unique([storyId, listenerId])
  @@index([listenerId, status])
}

// Sesiune de co-creatie: doi copii fizic impreuna aleg o poveste (a unuia
// dintre ei) si deseneaza pe hartie. Submit poza desenului → Claude vision
// valideaza ca match-uieste scena povestii si ca e potrivit varstei. Daca
// trece, Vertex AI Imagen genereaza o ilustratie digitala "transpusa" inspirata
// din desen + povestire. Album entry vizibil ambilor.
//
// userA  = initiatorul (cel care a pornit sesiunea, scaneaza NFC).
// userB  = celalalt copil (NFC tag scanat).
// storyId = una din povestile lui userA SAU userB (validat la /start).
// expiresAt = startedAt + 30min; dupa, /submit refuza si seteaza EXPIRED.
// originalImageKey/aiImageKey = chei GCS, signed URLs generate la GET.
enum CoCreationStatus {
  ACTIVE     // start trimis, asteapta submit poza
  PROCESSING // poza primita, ruleaza validare + image gen async
  COMPLETED  // valid + AI image gata, aparut in album
  REJECTED   // AI a refuzat (off-topic / continut nepotrivit)
  EXPIRED    // 30 min fara submit
  FAILED     // eroare interna pipeline (Imagen / GCS down)
}

model CoCreation {
  id               String   @id @default(cuid())
  userAId          String
  userBId          String
  storyId          String
  startedAt        DateTime @default(now())
  expiresAt        DateTime
  submittedById    String?
  submittedAt      DateTime?
  originalImageKey String?
  aiImageKey       String?
  aiValid          Boolean?
  aiFeedback       String?
  status           CoCreationStatus @default(ACTIVE)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userA User  @relation("CoCreationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User  @relation("CoCreationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([userAId, status])
  @@index([userBId, status])
  @@index([storyId])
}

model XpTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  sourceType  String
  sourceId    String?
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, sourceId])
  @@index([userId, createdAt])
}
