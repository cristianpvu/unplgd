// Schema initiala - extindem incremental pe masura ce adaugam features.
// Modele urmatoare (planificate): Friendship, DailyInteraction, Avatar, GameSession etc.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  birthDate    DateTime
  xp           Int      @default(0)
  level        Int      @default(1)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}
