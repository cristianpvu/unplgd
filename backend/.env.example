NODE_ENV=development
PORT=4000

# Postgres (host port from docker-compose, NOT container port)
DATABASE_URL=postgresql://unplgd:unplgd_dev@localhost:5433/unplgd?schema=public

# Redis
REDIS_URL=redis://localhost:6380

# Auth (genereaza cu: openssl rand -base64 48)
JWT_SECRET=change_me_in_production

# BLE token rotativ zilnic (genereaza cu: openssl rand -base64 48)
BLE_SECRET=change_me_in_production
